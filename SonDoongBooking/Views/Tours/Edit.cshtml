@model SonDoongBooking.Models.Tour

@{
    ViewData["Title"] = "Chỉnh sửa Tour";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-primary text-white py-3 rounded-top-4">
                    <h4 class="mb-0 fw-bold">Chỉnh sửa thông tin Tour</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="TenTour" class="form-label fw-bold">Tên Tour</label>
                            <input asp-for="TenTour" class="form-control" />
                            <span asp-validation-for="TenTour" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Gia" class="form-label fw-bold">Giá vé (VNĐ)</label>
                                <input asp-for="Gia" class="form-control" />
                                <span asp-validation-for="Gia" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SoNgay" class="form-label fw-bold">Số ngày</label>
                                <input asp-for="SoNgay" class="form-control" />
                                <span asp-validation-for="SoNgay" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SoChoConTrong" class="form-label fw-bold">Số chỗ còn có thể đặt</label>
                            <input asp-for="SoChoConTrong" class="form-control" type="number" />
                            <span asp-validation-for="SoChoConTrong" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="HinhAnh" class="form-label fw-bold">Đường dẫn hình ảnh (URL)</label>
                            <input asp-for="HinhAnh" class="form-control" />
                            <span asp-validation-for="HinhAnh" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MoTa" class="form-label fw-bold">Mô tả Tour</label>
                            <textarea asp-for="MoTa" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Cập nhật</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}