@model IEnumerable<SonDoongBooking.Models.Booking>
@{
    ViewData["Title"] = "Trung tâm Chỉ huy";
    
    // Thuật toán tính toán thống kê cho Giám đốc
    var tongDon = Model.Count();
    var tongKhach = Model.Sum(b => b.SoNguoi);
    var tongDoanhThu = Model.Sum(b => (b.Tour?.Gia ?? 0) * b.SoNguoi);
}

<div class="container-fluid bg-light py-5 min-vh-100">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-success mb-0">🛡️ TRUNG TÂM CHỈ HUY KTA NATURE</h2>
            <div class="d-flex gap-2">
                <a href="/Tours/Dashboard" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">📊 Thống kê</a>
                <a href="/" class="btn btn-dark rounded-pill px-4 fw-bold shadow-sm">Trở về Trang chủ</a>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card bg-success text-white border-0 shadow rounded-4 p-4 h-100">
                    <h5 class="opacity-75 fw-bold tracking-wider small">TỔNG ĐƠN ĐẶT</h5>
                    <h1 class="display-4 fw-bold mb-0">@tongDon</h1>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-primary text-white border-0 shadow rounded-4 p-4 h-100">
                    <h5 class="opacity-75 fw-bold tracking-wider small">TỔNG SỐ KHÁCH</h5>
                    <h1 class="display-4 fw-bold mb-0">@tongKhach <span class="fs-5 fw-normal">người</span></h1>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-warning text-dark border-0 shadow rounded-4 p-4 h-100">
                    <h5 class="opacity-75 fw-bold tracking-wider small">DOANH THU DỰ KIẾN</h5>
                    <h1 class="display-5 fw-bold mb-0">@tongDoanhThu.ToString("N0") <span class="fs-5 fw-normal">đ</span></h1>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0 fw-bold">Danh sách Đơn mới nhất</h5>
            </div>
            <div class="card-body p-0 table-responsive bg-white">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3">Mã Đơn</th>
                            <th>Khách hàng</th>
                            <th>Liên hệ</th>
                            <th>Tour đăng ký</th>
                            <th>Ngày đi</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Xử lý</th> 
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model) {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#@item.Id</td>
                                
                                <td>
                                    <div class="fw-bold text-dark fs-5">@item.TenKhachHang</div>
                                    <div class="text-primary small mb-1">
                                        <i class="bi bi-person-circle"></i> @item.EmailNguoiDat
                                    </div>
                                    <small class="text-muted fw-bold bg-light px-2 py-1 rounded border">
                                        @item.SoNguoi người
                                    </small>
                                </td>

                                <td>
                                    <span class="text-danger fw-bold">@item.SoDienThoai</span><br>
                                    <small class="text-muted">@item.NgayDat.ToString("dd/MM HH:mm")</small>
                                </td>
                                
                                <td>
                                    <span class="badge bg-success-subtle text-success border border-success px-2 py-1">
                                        @(item.Tour?.TenTour ?? "N/A")
                                    </span>
                                    <div class="mt-1 small">
                                        <span class="text-muted">Trống: </span>
                                        <span class="fw-bold @((item.Tour?.SoChoConTrong ?? 0) <= 5 ? "text-danger" : "text-primary")">
                                            @(item.Tour?.SoChoConTrong ?? 0) chỗ
                                        </span>
                                    </div>
                                </td>

                                <td class="fw-bold">@item.NgayDi.ToString("dd/MM/yyyy")</td>
                                
                                <td class="fw-bold text-success">
                                    @(((item.SoNguoi) * (item.Tour?.Gia ?? 0)).ToString("N0")) đ
                                </td>

                                <td>
                                    @if (item.TrangThai == "Đã duyệt") {
                                        <span class="badge bg-success px-2 py-1 shadow-sm">✅ Đã duyệt</span>
                                    } else if (item.TrangThai == "Đã hủy") {
                                        <span class="badge bg-danger px-2 py-1 shadow-sm">❌ Đã hủy</span>
                                    } else {
                                        <span class="badge bg-warning text-dark px-2 py-1 shadow-sm">⏳ Chờ xử lý</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="d-flex gap-2 justify-content-center">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary fw-bold">Duyệt</a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info fw-bold">Xem</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        @if(!Model.Any()) {
            <div class="alert alert-warning text-center mt-4 fw-bold border-0 shadow-sm rounded-4 py-4">
                Chưa có đơn hàng nào! Hãy ra trang chủ tự test một đơn xem sao nhé Giám đốc!
            </div>
        }
    </div>
</div>

@* Thêm link Bootstrap Icons để hiện icon người dùng *@
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">