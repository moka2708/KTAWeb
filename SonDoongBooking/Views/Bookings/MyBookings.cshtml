@model IEnumerable<SonDoongBooking.Models.Booking>
@{
    ViewData["Title"] = "Chuyến đi của tôi";
}

<div class="container py-5 mt-5 min-vh-100">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold text-dark border-start border-success border-5 ps-3">🎒 CHUYẾN ĐI CỦA TÔI</h2>
        <a href="/" class="btn btn-outline-success rounded-pill px-4 fw-bold">Quay lại trang chủ</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded-4 bg-white border border-dashed">
            <h1 class="display-1 text-muted opacity-25">🏜️</h1>
            <p class="fs-5 text-secondary">Cậu chưa đặt chuyến phiêu lưu nào cả.</p>
            <a href="/#tours" class="btn btn-success rounded-pill px-5 py-2 fw-bold shadow-sm mt-3">Khám phá ngay</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 tour-history-card">
                        <div class="row g-0 h-100">
                            <div class="col-4">
                                <img src="@item.Tour?.HinhAnh" class="img-fluid h-100 object-fit-cover" alt="@item.Tour?.TenTour">
                            </div>
                            
                            <div class="col-8">
                                <div class="card-body p-4 d-flex flex-column h-100">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h5 class="fw-bold text-dark mb-1">@item.Tour?.TenTour</h5>
                                            <div class="small text-secondary mb-1">
                                                <i class="bi bi-person-fill text-success"></i> <strong>Người đi:</strong> @item.TenKhachHang
                                            </div>
                                            <div class="small text-muted" style="font-size: 0.8rem;">
                                                <i class="bi bi-envelope"></i> @item.EmailNguoiDat
                                            </div>
                                        </div>
                                        
                                        @if (item.TrangThai == "Đã duyệt")
                                        {
                                            <span class="badge bg-success rounded-pill px-3 shadow-sm">✅ Đã chốt</span>
                                        }
                                        else if (item.TrangThai == "Đã hủy")
                                        {
                                            <span class="badge bg-danger rounded-pill px-3 shadow-sm">❌ Đã hủy</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill px-3 shadow-sm">⏳ Chờ xử lý</span>
                                        }
                                    </div>
                                    
                                    <p class="text-muted small mb-3">Mã đơn: #@item.Id | Đặt lúc: @item.NgayDat.ToString("dd/MM/yyyy")</p>
                                    
                                    <div class="mt-auto pt-3 border-top">
                                        <div class="row text-center">
                                            <div class="col-6 border-end">
                                                <small class="text-muted d-block">Khởi hành</small>
                                                <strong class="text-dark">@item.NgayDi.ToString("dd/MM/yyyy")</strong>
                                            </div>
                                            <div class="col-6">
                                                <small class="text-muted d-block">Tổng tiền (@item.SoNguoi người)</small>
                                                <strong class="text-success">@(((item.SoNguoi) * (item.Tour?.Gia ?? 0)).ToString("N0")) đ</strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    body { background-color: #f8f9fa; }
    .tour-history-card { transition: all 0.3s ease; border: 1px solid rgba(0,0,0,0.05); }
    .tour-history-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important; }
    .object-fit-cover { object-fit: cover; }
    
    /* Thêm icon nếu cậu chưa có Bootstrap Icons */
    @@import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css");
</style>