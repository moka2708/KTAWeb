    <script>
        AOS.init({ duration: 1000, once: true });
    </script>
    <script>
    document.addEventListener("DOMContentLoaded", function () {
        // 1. TRỊ BỆNH TRẮNG TRANG (Ép AOS nhận diện lại tọa độ sau khi F5)
        setTimeout(function() {
            window.dispatchEvent(new Event('resize'));
            AOS.refresh();
        }, 200); // Đợi 200ms để trình duyệt xếp xong bố cục rồi mới bung lụa

        // 2. TRỊ BỆNH ĐƠ SỐ (Dùng Intersection Observer)
        const counters = document.querySelectorAll('.counter');
        const speed = 40; // Tốc độ nhảy số (càng nhỏ càng nhanh)

        // Tạo một "Gương thần" để soi xem các con số đã lọt vào màn hình chưa
        const counterObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                // Nếu các con số đã xuất hiện trên màn hình (bất kể load mới hay F5)
                if (entry.isIntersecting) {
                    const counter = entry.target;
                    const target = +counter.getAttribute('data-target'); // Lấy số đích (38, 9, 200, 3)
                    
                    const updateCount = () => {
                        const current = +counter.innerText;
                        const increment = target / speed; // Tính bước nhảy
                        
                        if (current < target) {
                            counter.innerText = Math.ceil(current + increment);
                            setTimeout(updateCount, 30); // Cứ 30ms nhảy số 1 lần
                        } else {
                            counter.innerText = target; // Chốt hạ con số cuối cùng
                        }
                    };
                    
                    updateCount();
                    // Đếm xong thì hủy theo dõi để lúc cuộn lên cuộn xuống nó không bị đếm lại từ số 0
                    observer.unobserve(counter);
                }
            });
        }, { 
            threshold: 0.5 // Chỉ kích hoạt khi khối đếm số lộ ra ít nhất 50%
        });

        // Gắn "Gương thần" vào từng khối số
        counters.forEach(counter => {
            // Reset số về 0 trước khi đếm (phòng trường hợp bị kẹt)
            counter.innerText = '0'; 
            counterObserver.observe(counter);
        });
    });
</script>
