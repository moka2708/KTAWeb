@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-success text-white text-center py-4">
                    <h3 class="fw-bold mb-0">🌿 ĐĂNG NHẬP</h3>
                    <p class="mb-0 mt-2 opacity-75">Hệ thống quản trị KTA Nature</p>
                </div>
                <div class="card-body p-5 bg-light">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-4 shadow-sm rounded">
                            <input asp-for="Input.Email" class="form-control border-0" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-muted fw-bold">Email của bạn</label>
                            <span asp-validation-for="Input.Email" class="text-danger text-start d-block mt-1 small"></span>
                        </div>
                        
                        <div class="form-floating mb-4 shadow-sm rounded">
                            <input asp-for="Input.Password" class="form-control border-0" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="text-muted fw-bold">Mật khẩu</label>
                            <span asp-validation-for="Input.Password" class="text-danger text-start d-block mt-1 small"></span>
                        </div>
                        
                        <div class="checkbox mb-4 ms-1">
                            <label asp-for="Input.RememberMe" class="form-label fw-bold text-secondary cursor-pointer">
                                <input class="form-check-input me-2 bg-success border-success" asp-for="Input.RememberMe" />
                                Nhớ phiên đăng nhập
                            </label>
                        </div>
                        
                        <button id="login-submit" type="submit" class="btn btn-success btn-lg w-100 fw-bold py-3 shadow">
                            VÀO TRUNG TÂM CHỈ HUY
                        </button>
                        
                        <div class="mt-4 text-center">
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-success fw-bold text-decoration-none">
                                Chưa có tài khoản? Đăng ký ngay
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>