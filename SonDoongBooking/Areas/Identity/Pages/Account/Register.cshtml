@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white text-center py-4">
                    <h3 class="fw-bold mb-0">✨ MỞ TÀI KHOẢN MỚI</h3>
                    <p class="mb-0 mt-2 opacity-75 text-warning">Gia nhập đội ngũ KTA Nature</p>
                </div>
                <div class="card-body p-5 bg-light">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-4 shadow-sm rounded">
                            <input asp-for="Input.Email" class="form-control border-0" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-muted fw-bold">Nhập Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger text-start d-block mt-1 small"></span>
                        </div>
                        
                        <div class="form-floating mb-4 shadow-sm rounded">
                            <input asp-for="Input.Password" class="form-control border-0" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="text-muted fw-bold">Mật khẩu (Gồm chữ Hoa, số, ký tự...)</label>
                            <span asp-validation-for="Input.Password" class="text-danger text-start d-block mt-1 small"></span>
                        </div>
                        
                        <div class="form-floating mb-4 shadow-sm rounded">
                            <input asp-for="Input.ConfirmPassword" class="form-control border-0" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.ConfirmPassword" class="text-muted fw-bold">Nhập lại Mật khẩu</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger text-start d-block mt-1 small"></span>
                        </div>
                        
                        <button id="registerSubmit" type="submit" class="btn btn-dark btn-lg w-100 fw-bold py-3 shadow mt-2">
                            TẠO TÀI KHOẢN
                        </button>
                        
                        <div class="mt-4 text-center">
                            <a asp-page="./Login" class="text-dark fw-bold text-decoration-none">
                                Đã có tài khoản? <span class="text-success">Đăng nhập</span>
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>